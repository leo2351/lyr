{
  "expo": {
    "name": "lyr",
    "slug": "lyr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#030303"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#030303"
        }
      ]
