    },
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "D5mgVhKInvlkcmixeLXNCJfaTx_o0SuntV9oerhT"
      },
      "router": {}
    },
    "androidStatusBar": {
      "backgroundColor": "#030303"
    }
  }
}
